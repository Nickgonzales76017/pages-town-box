#!/usr/bin/env bash
# ─── Bonfyre Pages App Hook ──────────────────────────────────────────────────
set -euo pipefail

BONFYRE_BIN="${BONFYRE_BIN:-$HOME/.local/bin}"
export PATH="$BONFYRE_BIN:$PATH"

log() { printf "\033[0;33m[bonfyre]\033[0m %s\n" "$1"; }
err() { printf "\033[0;31m[bonfyre]\033[0m %s\n" "$1" >&2; }

require_bin() {
  for b in "$@"; do
    command -v "$b" >/dev/null 2>&1 || { err "Missing: $b (run 'make install' in bonfyre-oss)"; return 1; }
  done
}
MSG_FILE="$1"; [ "${2:-}" = "merge" ] && exit 0
MTG=$(git diff --cached --name-only -- 'input/meetings/' 2>/dev/null | wc -l | tr -d ' ')
HOT=$(git diff --cached --name-only -- 'input/hotline/' 2>/dev/null | wc -l | tr -d ' ')
ISS=$(git diff --cached --name-only -- 'input/issues/' 2>/dev/null | wc -l | tr -d ' ')
[ "$MTG" -eq 0 ] && [ "$HOT" -eq 0 ] && [ "$ISS" -eq 0 ] && exit 0
PARTS=()
[ "$MTG" -gt 0 ] && PARTS+=("${MTG} meeting(s)")
[ "$HOT" -gt 0 ] && PARTS+=("${HOT} hotline call(s)")
[ "$ISS" -gt 0 ] && PARTS+=("${ISS} issue(s)")
echo "[civic] $(IFS=', '; echo "${PARTS[*]}")" > "$MSG_FILE"
